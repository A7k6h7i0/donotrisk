TESSERACT_CMD=/usr/bin/tesseract
# Keep heavy engines opt-in unless explicitly enabled.
ENABLE_HEAVY_OCR_BY_DEFAULT=false
# In low-memory hosting, keep heavy engines disabled unless needed.
ENABLE_PADDLE_OCR=false
ENABLE_EASYOCR=false
# Throughput guards to avoid OCR timeouts on constrained hosts.
OCR_MAX_VARIANTS=3
OCR_MAX_PDF_PAGES=2
